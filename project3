}

int suma(int a, int b) {
	return a + b;
}

void par(int a) {
	if (a % 2 == 0)
		cout << "es par";

	else cout << "es impar";
}

int facto(int a) {
	b = 1;
	for (int i = 2; i <= a; i++) {
		b *= i;
	}
	return b;
}

double IVA(int a) {
	double c;
	c = a * (13/100);
	return c;
}
