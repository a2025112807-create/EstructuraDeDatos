		cout << "1. hacer una suma" << endl;
		cout << "2. ver si un numero es par" << endl;
		cout << "3. numero factorial" << endl;
		cout << "4. calcular el IVA" << endl;
		cout << "0. salir" << endl;
		cin >> op;
		switch (op) {
		case 1:
			cout << "suma" << endl;
			cout << "ingrese el primer valor: " << endl;
			cin >> a;
			cout << "ingrese el sugundo valor: " << endl;
			cin >> b;
			suma(a, b);
			break;
		case 2:
			cout << endl << "numero pares";
			cout << endl << "Escriba un numero: "; cin >> a;
			par(a);
			break;
		case 3:
			cout << "ingrese numero: ";
			cin >> a;
			b = 1;
			for (int i = 2; i <= a; i++) {
				b *= i;
			}
