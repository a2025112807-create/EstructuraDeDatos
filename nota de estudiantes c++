#include <iostream>
#include <string>
#define MAX 100

using namespace std;
void cargar(string nombre[], int nota[],int n);
void ordenar(string nombre[], int nota[],int n);
void mostrar(string nombre[], int nota[],int n);
int main()
{
    string name[MAX];
    int scores[MAX];
    int tam;
    do{
        cout<<"ingrese el numero de estudiantes: ";
        cin>>tam;
        
    }while(tam<0 || tam>MAX);
    cargar(name,scores,tam);
    ordenar(name,scores,tam);
    mostrar(name,scores,3);
    return 0;
}
void cargar(string nombre[], int nota[],int n){
    cout<<"Ingresa los datos"<<endl;
    for(int i=0; i<n; i++){
        cout<<i+1<<".estudiante: ";
        cin>>nombre[i];
        cout<<"nota: ";
        cin>>nota[i];
        cout<<"Registrado correctamente"<<endl;
    }
}
void ordenar(string nombre[], int nota[],int n){
    int nota_aux;
    string nom_aux;
    for(int i=0 ;i<n-1;i++){
        for(int j=i+1;j<n;j++){
            if(nota[j]>nota[i]){
                nota_aux=nota[j];
                nom_aux=nombre[j];
                nombre[j]=nombre[i];
                nota[i]=nota_aux;
                nombre[i]=nom_aux;
                
            }
        }
    }
}
void mostrar(string nombre[], int nota[],int n){
    cout<<"Las 3 mejores notas son: "<<endl;
    cout<<"Nombre\tNota"<<endl;
    for(int i=0; i<n; i++){
        cout<<nombre[i]<<"\t"<<nota[i]<<endl;
    }
}

